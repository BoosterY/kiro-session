#!/usr/bin/env bash
# kiro-session: Interactive session manager for Kiro CLI
# Install: symlink to a directory in PATH, e.g. ~/.local/bin/

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
VENV_PY="$SCRIPT_DIR/.venv/bin/python3"
PY="${VENV_PY:-python3}"
[ -x "$VENV_PY" ] && PY="$VENV_PY"

# --- Startup checks ---
INDEX_DB="$HOME/.kiro/session-index.db"

if [ -f "$INDEX_DB" ]; then
    "$PY" -c "
import sqlite3, time, sys
conn = sqlite3.connect('$INDEX_DB')
try:
    sessions = conn.execute('SELECT updated_at, user_turn_count FROM sessions').fetchall()
except:
    sys.exit(0)
now = time.time() * 1000
stale = sum(1 for u, tc in sessions if (now - u) / 86400000 > 90 and tc <= 2)
empty = sum(1 for _, tc in sessions if tc == 0)
warn = stale + empty
if warn > 0:
    print(f'\033[33m⚠  {warn} session(s) suggested for cleanup. Run: kiro-session cleanup\033[0m', file=sys.stderr)
" 1>&2
fi

# --- Background auto-enrich (Layer 1) ---
LAST_ENRICH="$HOME/.kiro/.enrich-last"
if [ -f "$INDEX_DB" ]; then
    RUN_ENRICH=false
    if [ ! -f "$LAST_ENRICH" ]; then
        RUN_ENRICH=true
    elif [ "$(find "$LAST_ENRICH" -mmin +1440 2>/dev/null)" ]; then
        RUN_ENRICH=true
    fi

    if [ "$RUN_ENRICH" = true ]; then
        # Check config: auto_enrich enabled?
        AUTO=$("$PY" -c "
import sys; sys.path.insert(0, '$SCRIPT_DIR/scripts')
from config import load_config, get
print('yes' if get(load_config(), 'llm.auto_enrich') else 'no')
" 2>/dev/null)

        if [ "$AUTO" = "yes" ]; then
            touch "$LAST_ENRICH"
            (
                sleep 1800  # 30 min delay
                "$PY" "$SCRIPT_DIR/scripts/kiro_session.py" index >/dev/null 2>&1
            ) &
            disown
        fi
    fi
fi

# --- Run main script ---
exec "$PY" "$SCRIPT_DIR/scripts/kiro_session.py" "$@"
